# DriftLock — Production Configuration
# Copy this to .env and set your own values!

# ── Admin Account ─────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Security (CHANGE THESE IN PRODUCTION!) ─────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=please-change-this-secret-key-in-production-min-32-chars
# Generate with: openssl rand -hex 16
ENCRYPTION_SALT=please-change-this-salt-16chars

# ── Core ──────────────────────────────────────────────────
DOMAIN=localhost
CORS_ORIGINS=http://localhost,http://localhost:80
SERVER_URL=http://localhost
AGENT_VERSION=1.0.0

# ── Database ──────────────────────────────────────────────
# In Docker, this MUST point to /app/data
DATABASE_URL=sqlite+aiosqlite:////app/data/driftlock.db
