# ── Core ──────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars-long
DOMAIN=localhost
SERVER_URL=http://localhost

# ── Admin Account (set on first run) ──────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── JWT ───────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:////app/data/driftlock.db

# ── Encryption (for CF token at rest) ─────────────────────
ENCRYPTION_SALT=dev-salt-16chars!

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────
UPDATE_RATE_LIMIT=60/minute
LOGIN_RATE_LIMIT=5/minute

# ── Agent Build ───────────────────────────────────────────
AGENT_VERSION=1.0.0
